# Veda backend — copy to server/.env and fill in your keys

# Required for TTS, karaoke, and Telugu translation
SARVAM_API_KEY=your_sarvam_api_key_here

# Optional — custom voice recording alignment (/transcribe)
OPENAI_API_KEY=your_openai_api_key_here

# Optional — local LLM size: 0.5B (default), 1.5B, or 3B
LOCAL_LLM_SIZE=3B
